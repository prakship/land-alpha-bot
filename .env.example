# Copy this file to .env and fill in your real values.
# The real .env is blocked by .gitignore and should NEVER be committed.

# Telegram Bot credentials
TELEGRAM_BOT_TOKEN=7123456789:AAHxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=-1001234567890

# ScrapingBee API key
SCRAPINGBEE_API_KEY=your-scrapingbee-key-here

# Alert filter thresholds
MAX_PRICE=200000
MAX_PPA=35000
MIN_ACRES=3
MIN_SCORE=6.0
